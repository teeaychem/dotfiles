#!/bin/sh

set -u

usage() {
    printf '%s\n' \
        'Usage: path_add [--append|--prepend] DIRECTORY...' \
        '' \
        'Print PATH with each existing DIRECTORY added once. The default is --append.' \
        '' \
        'Examples:' \
        "  export PATH=\"\$(path_add --prepend \"\$HOME/.local/bin\")\"" \
        "  set -gx PATH (string split : (path_add --prepend \"\$HOME/.local/bin\"))"
}

position=append

while [ "$#" -gt 0 ]; do
    case "$1" in
        -a|--append)
            position=append
            shift
            ;;
        -p|--prepend)
            position=prepend
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            printf 'path_add: unknown option: %s\n' "$1" >&2
            usage >&2
            exit 2
            ;;
        *)
            break
            ;;
    esac
done

if [ "$#" -eq 0 ]; then
    printf 'path_add: no directories specified\n' >&2
    usage >&2
    exit 2
fi

path=${PATH:-}

remove_directory() {
    target=$1
    remaining=$path
    path=

    while [ -n "$remaining" ]; do
        case "$remaining" in
            *:*)
                entry=${remaining%%:*}
                remaining=${remaining#*:}
                ;;
            *)
                entry=$remaining
                remaining=
                ;;
        esac

        [ "$entry" = "$target" ] ||
            path="${path:+$path:}$entry"
    done
}

prepend=
append=

for directory do
    while [ "$directory" != "/" ] && [ "${directory%/}" != "$directory" ]; do
        directory=${directory%/}
    done

    case "$directory" in
        *:*)
            printf 'path_add: directory contains a colon: %s\n' "$directory" >&2
            exit 2
            ;;
    esac

    [ -d "$directory" ] || continue

    case ":$prepend:$append:" in
        *":$directory:"*) continue ;;
    esac

    remove_directory "$directory"

    case "$position" in
        prepend)
            prepend="${prepend:+$prepend:}$directory"
            ;;
        append)
            append="${append:+$append:}$directory"
            ;;
    esac
done

path="${prepend}${prepend:+${path:+:}}${path}${path:+${append:+:}}${append}"
printf '%s\n' "$path"
