#!/bin/sh

set -eu

usage() {
    printf '%s\n' \
        'usage: ec [--host HOST] [FILE ...]' \
        '' \
        'Open files in a terminal Emacs client, starting a daemon if necessary.' \
        '' \
        '  -H, --host HOST  run emacsclient on HOST over SSH' \
        '  -h, --help       show this help'
}

die() {
    printf 'ec: %s\n' "$*" >&2
    exit 2
}

shell_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

host=

while [ "$#" -gt 0 ]; do
    case "$1" in
        -H | --host)
            [ "$#" -ge 2 ] || die "$1 requires a value"
            host=$2
            shift
            ;;
        -h | --help)
            usage
            exit
            ;;
        --)
            shift
            break
            ;;
        -*)
            usage >&2
            die "unknown option: $1"
            ;;
        *)
            break
            ;;
    esac
    shift
done

# An empty alternate editor makes emacsclient start a daemon if needed.
if [ -n "$host" ]; then
    remote_command="cd $(shell_quote "$PWD") && emacsclient --tty --alternate-editor='' --"
    for argument; do
        remote_command="$remote_command $(shell_quote "$argument")"
    done
    exec ssh -t "$host" "$remote_command"
fi

exec emacsclient --tty --alternate-editor= -- "$@"
