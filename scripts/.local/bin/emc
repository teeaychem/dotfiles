#!/bin/sh

set -eu

usage() {
    printf '%s\n' \
        'usage: emc [--host HOST] [--] [FILE ...]' \
        '' \
        'Open files in a terminal Emacs client, starting a daemon if necessary.' \
        '' \
        '  -H, --host HOST  run emacsclient on HOST over SSH' \
        '  -h, --help       show this help'
}

die() {
    printf 'emc: %s\n' "$*" >&2
    exit 2
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || die "command not found: $1"
}

shell_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

host=

while [ "$#" -gt 0 ]; do
    case "$1" in
        -H | --host)
            [ "$#" -ge 2 ] || die "$1 requires a value"
            host=$2
            shift
            ;;
        --host=*)
            host=${1#*=}
            [ -n "$host" ] || die "--host requires a value"
            ;;
        -h | --help)
            usage
            exit
            ;;
        --)
            shift
            break
            ;;
        -*)
            usage >&2
            die "unknown option: $1"
            ;;
        *)
            break
            ;;
    esac
    shift
done

if [ ! -t 0 ] || [ ! -t 1 ]; then
    die "an interactive terminal is required"
fi

# An empty alternate editor makes emacsclient start a daemon if needed.
if [ -n "$host" ]; then
    case "$host" in
        -*) die "invalid host: $host" ;;
    esac

    require_command ssh

    remote_error=$(shell_quote "emc: remote directory not found: $PWD")
    remote_command="cd $(shell_quote "$PWD") || { printf '%s\n' $remote_error >&2; exit 2; }; exec emacsclient --tty --alternate-editor='' --"
    for argument; do
        remote_command="$remote_command $(shell_quote "$argument")"
    done
    exec ssh -t -- "$host" "$remote_command"
fi

require_command emacsclient
exec emacsclient --tty --alternate-editor= -- "$@"
