#!/bin/sh

set -eu

die() {
    printf 'bootstrap-apt-host: %s\n' "$*" >&2
    exit 1
}

if [ "$#" -ne 1 ] || [ -z "$1" ]; then
    die 'usage: bootstrap-apt-host HOST'
fi
host=$1
command -v ssh >/dev/null 2>&1 || die 'ssh is required'

config_home=${XDG_CONFIG_HOME:-$HOME/.config}
apt_package_file=$config_home/apt/packages

[ -r "$apt_package_file" ] || die "cannot read $apt_package_file"

# Source package names from local config; nothing is copied remotely.
apt_packages=$(
    sed 's/#.*//' "$apt_package_file" |
        awk 'NF { for (i = 1; i <= NF; i++) print $i }'
)

# Keep package interpolation into the remote shell constrained to package names.
printf '%s\n' "$apt_packages" |
    awk '
        $0 !~ /^[A-Za-z0-9+._:-]+$/ {
            printf "bootstrap-apt-host: invalid package name: %s\n", $0 > "/dev/stderr"
            exit 1
        }
    '

printf 'bootstrap %s\n' "$host"
ssh -- "$host" 'sh -s' <<EOF
set -eu

if ! command -v apt-get >/dev/null 2>&1; then
    printf '%s\n' 'remote host needs apt-get' >&2
    exit 1
fi

# Use sudo only when the SSH user is not already root.
if [ "\$(id -u)" -eq 0 ]; then
    sudo=
elif command -v sudo >/dev/null 2>&1; then
    sudo=sudo
else
    printf '%s\n' 'remote host needs sudo or root login' >&2
    exit 1
fi

\$sudo apt-get update
\$sudo apt-get install -y -- $apt_packages
EOF
