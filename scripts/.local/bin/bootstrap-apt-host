#!/bin/sh

set -eu

die() {
    printf 'bootstrap-apt-host: %s\n' "$*" >&2
    exit 1
}

if [ "$#" -ne 1 ] || [ -z "$1" ]; then
    die 'usage: bootstrap-apt-host HOST'
fi
host=$1
command -v ssh >/dev/null 2>&1 || die 'ssh is required'

config_home=${XDG_CONFIG_HOME:-$HOME/.config}
apt_package_file=$config_home/apt/packages
brew_core_file=$config_home/brew/Brewfile.core

[ -r "$apt_package_file" ] || die "cannot read $apt_package_file"
[ -r "$brew_core_file" ] || die "cannot read $brew_core_file"

# Source package names from local config; nothing is copied remotely.
apt_packages=$(
    sed 's/#.*//' "$apt_package_file" |
        awk 'NF { for (i = 1; i <= NF; i++) print $i }'
)

brew_packages=$(
    sed -n 's/^[[:space:]]*brew "\([^"]*\)".*/\1/p' "$brew_core_file"
)

# Keep package interpolation into the remote shell constrained to package names.
printf '%s\n' "$apt_packages" "$brew_packages" |
    awk '
        $0 !~ /^[A-Za-z0-9+._:-]+$/ {
            printf "bootstrap-apt-host: invalid package name: %s\n", $0 > "/dev/stderr"
            exit 1
        }
    '

printf 'bootstrap %s\n' "$host"
ssh -- "$host" 'sh -s' <<EOF
set -eu

if ! command -v apt-get >/dev/null 2>&1; then
    printf '%s\n' 'remote host needs apt-get' >&2
    exit 1
fi

# Use sudo only when the SSH user is not already root.
if [ "\$(id -u)" -eq 0 ]; then
    sudo=
elif command -v sudo >/dev/null 2>&1; then
    sudo=sudo
else
    printf '%s\n' 'remote host needs sudo or root login' >&2
    exit 1
fi

\$sudo apt-get update
\$sudo apt-get install -y -- $apt_packages

# Install Homebrew under the user's home directory.
brew_prefix=\${HOMEBREW_PREFIX:-\$HOME/.linuxbrew}

if [ ! -x "\$brew_prefix/bin/brew" ]; then
    git clone --depth=1 https://github.com/Homebrew/brew "\$brew_prefix/Homebrew"
    mkdir -p "\$brew_prefix/bin"
    ln -sf ../Homebrew/bin/brew "\$brew_prefix/bin/brew"
fi

# Use the fresh Brew for this SSH command only; later dotfiles handle shell init.
eval "\$("\$brew_prefix/bin/brew" shellenv)"
brew update --force --quiet
brew install $brew_packages
EOF
