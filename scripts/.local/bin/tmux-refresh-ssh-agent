#!/bin/sh

# Point tmux's stable SSH agent socket at the agent forwarded by the latest
# attached client, so existing panes keep working after SSH reconnections.

set -eu

socket=$(tmux show-environment -g SSH_AUTH_SOCK 2>/dev/null || :)
case "$socket" in
    SSH_AUTH_SOCK=*)
        socket=${socket#SSH_AUTH_SOCK=}
        ;;
    *)
        exit 0
        ;;
esac

stable_dir=${XDG_RUNTIME_DIR:-"$HOME/.ssh"}
stable_socket="$stable_dir/tmux-ssh-agent.sock"

mkdir -p "$stable_dir"

if [ "$socket" = "$stable_socket" ]; then
    [ -S "$stable_socket" ] || exit 0
else
    [ -S "$socket" ] || exit 0

    temporary_socket="$stable_socket.$$"
    trap 'rm -f "$temporary_socket"' EXIT HUP INT TERM
    ln -s "$socket" "$temporary_socket"
    mv -f "$temporary_socket" "$stable_socket"
    trap - EXIT HUP INT TERM
fi

tmux set-environment -g SSH_AUTH_SOCK "$stable_socket"
