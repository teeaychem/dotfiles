#%Module

module-whatis {loads the macOS dotfiles environment}

setenv HOMEBREW_BUNDLE_FILE "$env(XDG_CONFIG_HOME)/brew/Brewfile"
setenv HOMEBREW_NO_AUTO_UPDATE 1
setenv HOMEBREW_NO_ENV_HINTS 1

foreach directory [list \
    /opt/homebrew/sbin \
    /opt/homebrew/bin \
    /usr/local/texlive/2026basic/bin/universal-darwin \
] {
    if {[file isdirectory $directory]} {
        prepend-path PATH $directory
    }
}
