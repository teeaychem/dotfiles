#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
packages="common"

case "$(uname -s)" in
    Darwin)
        packages="$packages darwin"
        ;;
    Linux)
        packages="$packages linux"
        ;;
    *)
        printf 'Unsupported operating system: %s\n' "$(uname -s)" >&2
        exit 1
        ;;
esac

exec stow \
    --dir="$repo_dir" \
    --target="${HOME:?HOME is not set}" \
    --no-folding \
    --ignore='(^|/)\.DS_Store$' \
    --restow \
    "$@" \
    $packages
