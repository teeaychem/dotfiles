#!/bin/sh

# Install packages listed in a file with apt.

set -eu

usage() {
    printf 'Usage: %s PACKAGE_FILE\n' "${0##*/}"
}

case "$#" in
    1)
        packages_file=$1
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac

if ! command -v apt-get >/dev/null 2>&1; then
    printf '%s\n' 'install-apt-packages: apt-get is required' >&2
    exit 1
fi

run_as_root() {
    if [ "$(id -u)" -eq 0 ]; then
        "$@"
    elif command -v sudo >/dev/null 2>&1; then
        sudo "$@"
    else
        printf '%s\n' \
            'install-apt-packages: run as root or install sudo' >&2
        exit 1
    fi
}

if [ ! -r "$packages_file" ]; then
    printf 'install-apt-packages: cannot read %s\n' "$packages_file" >&2
    exit 1
fi

set --
set -f
while IFS= read -r line || [ -n "$line" ]; do
    line=${line%%#*}

    for package in $line; do
        case "$package" in
            -*|*[!A-Za-z0-9+._:-]*)
                printf 'install-apt-packages: invalid package name: %s\n' \
                    "$package" >&2
                exit 1
                ;;
        esac

        set -- "$@" "$package"
    done
done < "$packages_file"
set +f

if [ "$#" -eq 0 ]; then
    printf 'install-apt-packages: no packages listed in %s\n' \
        "$packages_file" >&2
    exit 1
fi

run_as_root apt-get update
run_as_root apt-get install -y -- "$@"
