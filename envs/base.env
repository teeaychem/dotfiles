# XDG base directories
XDG_CONFIG_HOME="$HOME/.config"
XDG_STATE_HOME="$HOME/.local/state"
XDG_DATA_HOME="$HOME/.local/share"
XDG_CACHE_HOME="$HOME/.cache"

# XDG user directories
# https://www.freedesktop.org/wiki/Software/xdg-user-dirs/
XDG_DESKTOP_DIR="$HOME/Desktop"
XDG_DOWNLOAD_DIR="$HOME/Downloads"
XDG_TEMPLATES_DIR="$HOME/Templates"
XDG_PUBLICSHARE_DIR="$HOME/Public"
XDG_DOCUMENTS_DIR="$HOME/Documents"
XDG_MUSIC_DIR="$HOME/Music"
XDG_PICTURES_DIR="$HOME/Pictures"
XDG_VIDEOS_DIR="$HOME/Videos"

# General tools
EDITOR="nvim"
MANPAGER="nvim +Man!"
FD_OPTIONS="--hidden --follow"
FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git"

# Node.js
NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/npmrc"

# OCaml
OPAMROOT="$XDG_DATA_HOME/opam"

# Python
PYTHONPYCACHEPREFIX="$XDG_CACHE_HOME/python_cache"
PYTHON_HISTORY="$XDG_CACHE_HOME/python/history"
IPYTHONDIR="$XDG_CACHE_HOME/ipython"
MPLCONFIGDIR="$XDG_CACHE_HOME/matplotlib"

# Docker
DOCKER_CONFIG="$XDG_CONFIG_HOME/docker"

# Hunspell
DICTIONARY="en_GB"
DICPATH="$XDG_DATA_HOME/hunspell"

# Less
LESSHISTFILE="$XDG_STATE_HOME/less/history"

# Keras
KERAS_HOME="$XDG_DATA_HOME/keras"

# Lean
ELAN_HOME="$HOME/.local/opt/elan"
