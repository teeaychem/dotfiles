# This is the configuration file for Ghostty.
#
# ghostty +show-config --default --docs
# https://ghostty.org/docs/config.

auto-update = off

cursor-style = block

font-family = "M+1Code Nerd Font Mono"

# Disable ligatures
font-feature = -dlig
font-feature = -liga
font-feature = -calt

font-size = 14

keybind = global:opt+super+space=toggle_quick_terminal
keybind = opt+shift+super+p=toggle_command_palette

keybind = super+0=unbind
keybind = super++=unbind
keybind = super+-=unbind
keybind = super+==unbind

# macOS owned
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind

macos-option-as-alt = true
macos-titlebar-proxy-icon = hidden

mouse-hide-while-typing = true

shell-integration-features = no-sudo,title,ssh-env,no-ssh-terminfo,path

unfocused-split-opacity = 0.5
